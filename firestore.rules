rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if user is admin
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAuth() && (request.auth.uid == uid || isAdmin());
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();

      // Reactions subcollection
      match /reactions/{uid} {
        allow read: if isAuth();
        allow write: if isAuth() && request.auth.uid == uid;
      }
    }

    // Policies collection
    match /policies/{policyId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();

      // Acknowledgments subcollection (legacy, for policy acks)
      match /acknowledgments/{uid} {
        allow read: if isAuth();
        allow create: if isAuth() && request.auth.uid == uid;
      }
    }

    // Standalone Acknowledgments collection
    match /acknowledgments/{ackId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();

      // Responses subcollection
      match /responses/{uid} {
        allow read: if isAuth();
        allow create: if isAuth() && request.auth.uid == uid;
      }
    }

    // Social Posts collection
    match /socialPosts/{postId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.blocked == false;
      allow update: if isAuth()
        && (
          (resource.data.authorUid == request.auth.uid
            && request.resource.data.blocked == resource.data.blocked)
          || isAdmin()
        );
      allow delete: if isAuth()
        && (resource.data.authorUid == request.auth.uid || isAdmin());

      // Reactions subcollection
      match /reactions/{uid} {
        allow read: if isAuth();
        allow write: if isAuth() && request.auth.uid == uid;
      }

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth()
          && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if isAuth()
          && (resource.data.authorUid == request.auth.uid || isAdmin());
      }

      // Reports subcollection
      match /reports/{uid} {
        allow read: if isAuth();
        allow create: if isAuth() && request.auth.uid == uid;
      }
    }
  }
}
